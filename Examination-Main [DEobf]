local function setupQTE(enabled)
    if enabled then
        if not QTEConnection then
            QTEConnection = QTE.OnClientEvent:Connect(function(i)
                local k = KB[tostring(i)]
                if k then
                    task.wait(0.2)
                    Press(k)
                end
            end)
        end
