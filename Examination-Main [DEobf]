function Chass_getRoot(model)
    return model:FindFirstChild("HumanoidRootPart")
        or model:FindFirstChild("Torso")
        or model:FindFirstChildWhichIsA("BasePart")
end

function Chass_belongsToAPlayer(obj)
    local myChar = Chass_getCharacter()
    if myChar and (obj == myChar or obj:IsDescendantOf(myChar)) then
        return true
    end
    for _, p in ipairs(Players:GetPlayers()) do
        local pc = p.Character
        if pc and (obj == pc or obj:IsDescendantOf(pc)) then
            return true
        end
    end
    return false
end

function Chass_nameMatchesWhitelist(name)
    local whitelist = {
        "Bomber", "ChemicalFury", "Chimera", "CombatEngineer", "CrawlerLurker",
        "Dave", "Fury", "Gilbert", "Gunner", "Lurker", "Mikhail",
        "Mutant crawler", "Mutant", "RIF AK", "RIF KS", "RIF Miniboss",
        "RIF STATIONARY", "Radaways", "Riser", "SIN", "Shielder", "Slasher",
    }
    local lname = name:lower()
    for _, pattern in ipairs(whitelist) do
        local lpattern = pattern:lower()
        if lname:sub(1, #lpattern) == lpattern then
            return true
        end
    end
    return false
end

function Chass_isNPC(obj)
    if not obj:IsA("Model") then return false end
    if obj:IsA("Accessory") or obj:IsA("Tool") or obj:IsA("Hat") then return false end
    if not Chass_nameMatchesWhitelist(obj.Name) then return false end
    if Chass_belongsToAPlayer(obj) then return false end
    if not Chass_getRoot(obj) then return false end
    return true
end

Chass_FADE_IN = TweenInfo.new(0.5, Enum.EasingStyle.Sine, Enum.EasingDirection.Out)
Chass_FADE_OUT = TweenInfo.new(0.5, Enum.EasingStyle.Sine, Enum.EasingDirection.In)

function Chass_heartbeatAnimation(imageLabel)
    if not imageLabel or not imageLabel.Parent then return end
    local beatIn = TweenInfo.new(0.5, Enum.EasingStyle.Sine, Enum.EasingDirection.Out)
    local beatOut = TweenInfo.new(0.5, Enum.EasingStyle.Sine, Enum.EasingDirection.In)
    while imageLabel and imageLabel.Parent do
        TweenService:Create(imageLabel, beatIn, {
            ImageTransparency = 0.2
        }):Play()
        task.wait(0.5)
        if not imageLabel or not imageLabel.Parent then break end
        TweenService:Create(imageLabel, beatOut, {
            ImageTransparency = 0.8
        }):Play()
        task.wait(0.5)
    end
end

function Chass_espHeartbeatAnimation(highlight)
    if not highlight or not highlight.Parent then return end
    local beatIn = TweenInfo.new(0.5, Enum.EasingStyle.Sine, Enum.EasingDirection.Out)
    local beatOut = TweenInfo.new(0.5, Enum.EasingStyle.Sine, Enum.EasingDirection.In)
    while highlight and highlight.Parent do
        TweenService:Create(highlight, beatIn, {
            FillTransparency = 0.1,
            OutlineTransparency = 0.1
        }):Play()
        task.wait(0.5)
        if not highlight or not highlight.Parent then break end
        TweenService:Create(highlight, beatOut, {
            FillTransparency = 0.5,
            OutlineTransparency = 0.5
        }):Play()
        task.wait(0.5)
    end
end

function Chass_pulseHeart(imageLabel)
    if not imageLabel or not imageLabel.Parent then return end
    local pulseInfo = TweenInfo.new(0.15, Enum.EasingStyle.Sine, Enum.EasingDirection.Out)
    TweenService:Create(imageLabel, pulseInfo, {
        Size = UDim2.new(0.35, 0, 0.35, 0),
        Position = UDim2.new(0.325, 0, 0.325, 0),
    }):Play()
    task.delay(0.15, function()
        if not imageLabel or not imageLabel.Parent then return end
        local pulseBack = TweenInfo.new(0.25, Enum.EasingStyle.Sine, Enum.EasingDirection.In)
        TweenService:Create(imageLabel, pulseBack, {
            Size = UDim2.new(0.35, 0, 0.35, 0),
            Position = UDim2.new(0.325, 0, 0.325, 0),
        }):Play()
    end)
end

function Chass_smoothRemoveEffects(npc)
    if Chass.removingNPCs[npc] then return end
    Chass.removingNPCs[npc] = true
    local data = Chass.activeNPCs[npc]
    if not data then 
        Chass.removingNPCs[npc] = nil
        return 
    end
    data.aliveCheck()
    local fadeComplete = false
    local highlightComplete = false
    if data.billboard and data.billboard.Parent then
        local image = data.billboard:FindFirstChild("Heart")
        if image then
            TweenService:Create(image, Chass_FADE_OUT, {
                ImageTransparency = 1
            }):Play()
            task.delay(0.5, function()
                if data.billboard and data.billboard.Parent then
                    data.billboard:Destroy()
                end
                fadeComplete = true
                if highlightComplete then
                    Chass.activeNPCs[npc] = nil
                    Chass.removingNPCs[npc] = nil
                end
            end)
        else
            if data.billboard then
                data.billboard:Destroy()
            end
            fadeComplete = true
            if highlightComplete then
                Chass.activeNPCs[npc] = nil
                Chass.removingNPCs[npc] = nil
            end
        end
    else
        fadeComplete = true
    end
    if data.highlight and data.highlight.Parent then
        TweenService:Create(data.highlight, Chass_FADE_OUT, {
            FillTransparency = 1,
            OutlineTransparency = 1
        }):Play()
        task.delay(0.5, function()
            if data.highlight and data.highlight.Parent then
                data.highlight:Destroy()
            end
            highlightComplete = true
            if fadeComplete then
                Chass.activeNPCs[npc] = nil                Chass.removingNPCs[npc] = nil
            end
        end)
    else
        highlightComplete = true
    end
    if data.diedConn then
        data.diedConn:Disconnect()
    end
    if fadeComplete and highlightComplete then
        Chass.activeNPCs[npc] = nil
        Chass.removingNPCs[npc] = nil
    end
end

function Chass_addEffects(npc)
    if Chass.activeNPCs[npc] or Chass.removingNPCs[npc] then return end
    local highlight = Instance.new("Highlight")
    highlight.FillColor           = Config.ChassGlowColor
    highlight.OutlineColor        = Config.ChassGlowColor
    highlight.FillTransparency    = 0.5
    highlight.OutlineTransparency = 0.5
    highlight.Adornee             = npc
    highlight.Parent              = npc
    TweenService:Create(highlight, Chass_FADE_IN, {
        FillTransparency = Config.ChassGlowFillAlpha,
        OutlineTransparency = Config.ChassGlowOutlineAlpha
    }):Play()
    local root = Chass_getRoot(npc)
    local billboard = Instance.new("BillboardGui")
    billboard.Name           = "HeartNPC_Billboard"
    billboard.Size           = UDim2.new(0, Config.ChassHeartSize, 0, Config.ChassHeartSize)
    billboard.StudsOffset    = Config.ChassHeartOffset
    billboard.AlwaysOnTop    = Config.ChassHeartAlwaysOnTop
    billboard.LightInfluence = 0
    billboard.Parent         = root
    local image = Instance.new("ImageLabel")
    image.Name                   = "Heart"
    image.Size                   = UDim2.new(0.35, 0, 0.35, 0)
    image.Position               = UDim2.new(0.325, 0, 0.325, 0)
    image.BackgroundTransparency = 1
    image.ImageTransparency      = 0.8
    image.Image                  = Config.ChassHeartImage
    image.ScaleType              = Enum.ScaleType.Fit
    image.Parent                 = billboard
    TweenService:Create(image, Chass_FADE_IN, {
        ImageTransparency = 0
    }):Play()
    local alive = true
    local heartbeatThread = task.spawn(function()
        while alive and npc.Parent do
            Chass_heartbeatAnimation(image)
            task.wait(1)
        end
    end)
    local espHeartbeatThread = task.spawn(function()
        while alive and npc.Parent do
            Chass_espHeartbeatAnimation(highlight)
            task.wait(1)
        end
    end)
    local pulseThread = task.spawn(function()
        while alive and npc.Parent do
            Chass_pulseHeart(image)
            task.wait(Config.ChassPulseInterval)
        end
    end)
    local diedConn = nil
    local humanoid = npc:FindFirstChildOfClass("Humanoid")
    if humanoid then
        diedConn = humanoid.Died:Connect(function()
            Chass_smoothRemoveEffects(npc)
        end)
    end
    Chass.activeNPCs[npc] = {
        highlight = highlight,
        billboard = billboard,
        heartbeatThread = heartbeatThread,
        espHeartbeatThread = espHeartbeatThread,
        pulseThread = pulseThread,
        diedConn  = diedConn,
        aliveCheck = function() alive = false end,
    }
end

