local function GetBodyPartPosition(character, bodyPart)
    if not character then return nil end
    
    if bodyPart == "Head" then
        local head = character:FindFirstChild("Head")
        if head then return head.Position end
    elseif bodyPart == "HRP" then
        local hrp = character:FindFirstChild("HumanoidRootPart")
        if hrp then return hrp.Position end
    elseif bodyPart == "Torso" then
        local torso = character:FindFirstChild("UpperTorso") or character:FindFirstChild("Torso") or character:FindFirstChild("HumanoidRootPart")
        if torso then return torso.Position end
    end
    
    local hrp = character:FindFirstChild("HumanoidRootPart")
    if hrp then return hrp.Position end
    return nil
end

local function IsTargetVisible(targetPosition)
    if not Config.WallCheck then return true end
    
    local character = LocalPlayer.Character
    if not character then return false end
    
    local cameraPos = Camera.CFrame.Position
    local direction = (targetPosition - cameraPos)
    local distance = direction.Magnitude
    direction = direction.Unit
    
    local params = RaycastParams.new()
    params.FilterType = Enum.RaycastFilterType.Blacklist
    params.FilterDescendantsInstances = {character, LocalPlayer.Character, CurrentTarget}
    
    local rayResult = workspace:Raycast(cameraPos, direction * distance, params)
    
    if rayResult then
        local hit = rayResult.Instance
        
        if hit then
            local hitChar = hit:FindFirstAncestorWhichIsA("Model")
            
            if hitChar and (hitChar == CurrentTarget or Players:GetPlayerFromCharacter(hitChar) or table.find(CachedMobs, hitChar)) then
                return true
            end
            
            local isSolidWall = false
            
            if hit:IsA("BasePart") then
                local isInvisible = hit.Transparency >= 0.95
                local hasCollision = hit.CanCollide
                local isTransparentMaterial = (hit.Material == Enum.Material.Neon or 
                                               hit.Material == Enum.Material.Glass or 
                                               hit.Material == Enum.Material.ForceField)
                
                if hasCollision and not isInvisible and not isTransparentMaterial then
                    isSolidWall = true
                end
            end
            
            if isSolidWall then
                return false
            else
                local newStart = hit.Position + direction * 0.5
                local newDistance = distance - (newStart - cameraPos).Magnitude
                
                if newDistance > 0 then
                    local secondRay = workspace:Raycast(newStart, direction * newDistance, params)
                    if secondRay then
                        local secondHit = secondRay.Instance
                        local secondChar = secondHit and secondHit:FindFirstAncestorWhichIsA("Model")
                        
                        if secondChar and (secondChar == CurrentTarget or Players:GetPlayerFromCharacter(secondChar) or table.find(CachedMobs, secondChar)) then
                            return true
                        end
                        
                        if secondHit:IsA("BasePart") and secondHit.CanCollide and secondHit.Transparency < 0.95 then
                            return false
                        else
                            return true
                        end
                    else
                        return true
                    end
                else
                    return true
                end
            end
        end
    end
    
    return true
end

local function FindBestTarget()
    local character = LocalPlayer.Character
    if not character then return nil end
    
    local viewportCenter = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)
    
    local bestTarget = nil
    local bestScore = math.huge
    
    for _, player in pairs(Players:GetPlayers()) do
        if player ~= LocalPlayer then
            local targetChar = player.Character
            if targetChar and targetChar:FindFirstChild("HumanoidRootPart") then
                local humanoid = targetChar:FindFirstChildOfClass("Humanoid")
                if humanoid and humanoid.Health > 0 then
                    local targetPos = GetBodyPartPosition(targetChar, Config.BodyPartLock)
                    if targetPos then
                        local screenPos, onScreen = Camera:WorldToViewportPoint(targetPos)
                        
                        if onScreen then
                            local distanceToCenter = (Vector2.new(screenPos.X, screenPos.Y) - viewportCenter).Magnitude
                            
                            if distanceToCenter <= Config.FOVCircleSize then
                                if IsTargetVisible(targetPos) then
                                    local score = distanceToCenter
                                    if score < bestScore then
                                        bestScore = score
                                        bestTarget = targetChar
                                    end
                                end
                            end
                        end
                    end
                end
            end
        end
    end
    
    for _, mob in pairs(CachedMobs) do
        if mob and mob ~= character then
            local humanoid = mob:FindFirstChildOfClass("Humanoid")
            if humanoid and humanoid.Health > 0 then
                local targetPos = GetBodyPartPosition(mob, Config.BodyPartLock)
                if targetPos then
                    local screenPos, onScreen = Camera:WorldToViewportPoint(targetPos)
                    
                    if onScreen then
                        local distanceToCenter = (Vector2.new(screenPos.X, screenPos.Y) - viewportCenter).Magnitude
                        
                        if distanceToCenter <= Config.FOVCircleSize then
                            if IsTargetVisible(targetPos) then
                                local score = distanceToCenter
                                if score < bestScore then
                                    bestScore = score
                                    bestTarget = mob
                                end
                            end
                        end
                    end
                end
            end
        end
    end
    
    return bestTarget, bestScore
end

local function ApplyAimlock()
    if not Config.AimlockEnabled then 
        if CurrentTarget then CurrentTarget = nil end
        return 
    end
    
    local character = LocalPlayer.Character
    if not character then return end
    
    local target, score = FindBestTarget()
    
    if target and score < Config.FOVCircleSize then
        CurrentTarget = target
        
        local targetPos = GetBodyPartPosition(target, Config.BodyPartLock)
        if not targetPos then return end
        
        local lockStrength = Config.LockPower / 100
        local cameraPos = Camera.CFrame.Position
        
        local directionToTarget = (targetPos - cameraPos).Unit
        local currentDirection = Camera.CFrame.LookVector
        
        local newDirection = currentDirection:Lerp(directionToTarget, lockStrength)
        
        local newCFrame = CFrame.lookAt(cameraPos, cameraPos + newDirection)
        Camera.CFrame = newCFrame
    else
        CurrentTarget = nil
    end
end

