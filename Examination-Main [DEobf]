local function BreakGasmask()
    local playerGui = LocalPlayer:FindFirstChild("PlayerGui")
    if not playerGui then return false end
    
    local gasmaskGui = playerGui:FindFirstChild("Gasmask")
    if not gasmaskGui then return false end
    
    local maskHole = gasmaskGui:FindFirstChild("MaskHole")
    local glass = gasmaskGui:FindFirstChild("Glass")
    
    if maskHole then
        if maskHole:IsA("ImageLabel") then
            maskHole.ImageTransparency = 0
            maskHole.Visible = true
        elseif maskHole:IsA("Frame") then
            maskHole.Visible = true
            for _, child in pairs(maskHole:GetDescendants()) do
                if child:IsA("ImageLabel") then
                    child.ImageTransparency = 0
                    child.Visible = true
                end
            end
        end
    end
    
    local crackSound = Instance.new("Sound")
    crackSound.SoundId = "rbxassetid://632831227"
    crackSound.Volume = 1
    crackSound.Parent = gasmaskGui
    crackSound:Play()
    Debris:AddItem(crackSound, 3)
    
    if glass and glass:IsA("ImageLabel") then
        local originalTransparency = glass.ImageTransparency
        TweenService:Create(glass, TweenInfo.new(0.1), { ImageTransparency = 0.5 }):Play()
        task.wait(0.05)
        TweenService:Create(glass, TweenInfo.new(0.5), { ImageTransparency = originalTransparency }):Play()
    end
    
    return true
end

