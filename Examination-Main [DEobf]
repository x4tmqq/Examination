function Chass_clearAll()
    for npc in pairs(Chass.activeNPCs) do
        Chass_smoothRemoveEffects(npc)
    end
    if Chass.heartSound and Chass.heartSound.IsPlaying then Chass.heartSound:Stop() end
end

function Chass_init()
    if Chass.heartSound then
        Chass.heartSound:Destroy()
    end
    Chass.heartSound = Instance.new("Sound")
    Chass.heartSound.SoundId = Config.ChassSoundId
    Chass.heartSound.Volume = Config.ChassSoundVolume
    Chass.heartSound.Looped = true
    Chass.heartSound.RollOffMaxDistance = 0
    Chass.heartSound.Parent = workspace
end

function Chass_scan()
    if not Config.ChassEnabled then
        Chass_clearAll()
        return
    end
    local char = Chass_getCharacter()
    if not char then return end
    local myRoot = char:FindFirstChild("HumanoidRootPart")
    if not myRoot then return end
    local myPos   = myRoot.Position
    local nearby  = {}
    local scanRoot = workspace
    local folder = workspace:FindFirstChild("Characters")
    if folder then scanRoot = folder end
    local list = scanRoot:GetDescendants()
    local seen = {}
    for _, obj in ipairs(list) do
        if Chass_isNPC(obj) then
            local ancestor = obj.Parent
            local isNested = false
            while ancestor and ancestor ~= scanRoot do
                if seen[ancestor] then
                    isNested = true
                    break
                end
                ancestor = ancestor.Parent
            end
            if not isNested then
                seen[obj] = true
                local npcRoot = Chass_getRoot(obj)
                local humanoid = obj:FindFirstChildOfClass("Humanoid")
                local isDead = humanoid and humanoid.Health <= 0
                if npcRoot and not isDead then
                    local dist = (npcRoot.Position - myPos).Magnitude
                    if dist <= Config.ChassDetectionRadius then
                        nearby[obj] = true
                        Chass_addEffects(obj)
                    end
                end
            end
        end
    end
    for npc in pairs(Chass.activeNPCs) do
        if not nearby[npc] then
            Chass_smoothRemoveEffects(npc)
        end
    end
    local hasNearby = false
    for npc in pairs(Chass.activeNPCs) do
        if not Chass.removingNPCs[npc] then
            hasNearby = true
            break
        end
    end
    if hasNearby and not Chass.heartSound.IsPlaying then
        Chass.heartSound:Play()
    elseif not hasNearby and Chass.heartSound.IsPlaying then
        Chass.heartSound:Stop()
    end
end

