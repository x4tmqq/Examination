            QTEConnection:Disconnect()
            QTEConnection = nil
        end
    end
end

function deleteSlasherAxe()
    local characters = Workspace:FindFirstChild("Characters")
    if not characters then return end
    for i = 1, 5 do
        local slasherName = "Slasher" .. i
        local slasher = characters:FindFirstChild(slasherName)
        if slasher then
            local rightArm = slasher:FindFirstChild("Right Arm")
            if rightArm then
                local handle = rightArm:FindFirstChild("Handle")
                if handle then
                    handle:Destroy()
                end
            end
        end
    end
end

function setupAutoRemoveAxe()
    if AutoRemoveAxeConnection then AutoRemoveAxeConnection:Disconnect() end
    if AutoRemoveAxeActive then
        AutoRemoveAxeConnection = workspace.DescendantAdded:Connect(function(desc)
            if AutoRemoveAxeActive then
                task.wait(0.1)
                if desc.Name == "Handle" and desc.Parent and desc.Parent.Name == "Right Arm" then
                    local slasher = desc.Parent.Parent
                    if slasher and slasher.Name:match("Slasher%d") then
                        desc:Destroy()
                    end
                end
            end
        end)
    end
end

