function getTracer(id)
    if not Drawing then return nil end
    if not tracerCache[id] then
        local line = Drawing.new("Line")
        line.Thickness = 1.5
        line.Transparency = 1
        tracerCache[id] = line
    end
    return tracerCache[id]
end

