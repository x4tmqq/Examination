        function getDisplayName(objName)
            local name = objName:lower()
            if name:find("mutant crawler") then return "Crawler Mutant"
            elseif name:find("lurker") then return "Lurker"
            elseif name:find("mutant") and not name:find("crawler") then return "Mutant"
            elseif name:find("riser") then return "Riser"
            elseif name:find("slasher") then return "Slasher"
            elseif name:find("gilbert") then return "Gilbert"
            elseif name:find("mikhail") then return "Mikhail"
            elseif name:find("chimera") then return "Chimera"
            else return objName
            end
        end

        function updateElsherHelper()
            local char = LocalPlayer.Character
            if not char then return end
            local hrp = char:FindFirstChild("HumanoidRootPart")
            if not hrp then return end

            local targetConfig = {
                ["mutant crawler"] = 1,
                ["lurker"] = 3,
                ["mutant"] = 2,
                ["mikhail"] = 1,
                ["riser"] = 2,
                ["slasher"] = 2,
                ["gilbert"] = 1,
                ["chimera"] = 1,
            }

            local found = {}
            for _, obj in ipairs(workspace:GetDescendants()) do
                if obj:IsA("Model") and obj:FindFirstChildOfClass("Humanoid") then
                    local name = obj.Name:lower()
                    local matchedKey = nil
                    for key in pairs(targetConfig) do
                        if name:find(key) then
                            matchedKey = key
                            break
                        end
                    end
                    if matchedKey then
                        if obj == LocalPlayer.Character then continue end
                        if Players:GetPlayerFromCharacter(obj) then continue end
                        local hum = obj:FindFirstChildOfClass("Humanoid")
                        if hum and hum.Health > 0 then
                            local root = obj:FindFirstChild("HumanoidRootPart") or obj:FindFirstChild("Torso")
                            if root then
                                local dist = (root.Position - hrp.Position).Magnitude
                                table.insert(found, {
                                    obj = obj,
                                    key = matchedKey,
                                    displayName = getDisplayName(obj.Name),
                                    health = math.floor(hum.Health),
                                    dist = dist
                                })
                            end
                        end
                    end
                end
            end

            local toHighlight = {}
            for key, limit in pairs(targetConfig) do
                local filtered = {}
                for _, entry in ipairs(found) do
                    if entry.key == key then
                        table.insert(filtered, entry)
                    end
                end
                table.sort(filtered, function(a, b) return a.dist < b.dist end)
                for i = 1, math.min(limit, #filtered) do
                    table.insert(toHighlight, filtered[i])
                end
            end

            local currentObjs = {}
            for _, entry in ipairs(toHighlight) do
                currentObjs[entry.obj] = {
                    displayName = entry.displayName,
                    health = entry.health
                }
            end

            for obj, hl in pairs(ElsherHighlights) do
                if not currentObjs[obj] then
                    hl:Destroy()
                    ElsherHighlights[obj] = nil
                end
            end

            for obj, bill in pairs(ElsherBillboards) do
                if not currentObjs[obj] then
                    bill:Destroy()
                    ElsherBillboards[obj] = nil
                end
            end

            for obj, data in pairs(currentObjs) do
                if not ElsherHighlights[obj] then
                    local hl = Instance.new("Highlight")
                    hl.FillColor = Color3.fromRGB(255, 50, 50)
                    hl.OutlineColor = Color3.fromRGB(255, 255, 255)
                    hl.FillTransparency = 0.7
                    hl.OutlineTransparency = 1.0
                    hl.Adornee = obj
                    hl.Parent = obj
                    ElsherHighlights[obj] = hl
                end

                if not ElsherBillboards[obj] then
                    local root = obj:FindFirstChild("HumanoidRootPart") or obj:FindFirstChild("Torso")
                    if root then
                        local bill = Instance.new("BillboardGui")
                        bill.Name = "ElsherTag"
                        bill.Size = UDim2.new(0, 200, 0, 25)
                        bill.StudsOffset = Vector3.new(0, 3.5, 0)
                        bill.AlwaysOnTop = true
                        bill.LightInfluence = 0
                        bill.Parent = root
                        local label = Instance.new("TextLabel")
                        label.Size = UDim2.new(1, 0, 1, 0)
                        label.BackgroundTransparency = 1
                        label.TextColor3 = Color3.fromRGB(255, 0, 0)
                        label.TextStrokeTransparency = 1
                        label.Font = Enum.Font.GothamBold
                        label.TextSize = 12
                        label.Text = data.displayName .. " [" .. data.health .. " HP]"
                        label.TextScaled = false
                        label.Parent = bill
                        ElsherBillboards[obj] = bill
                    end
                else
                    local bill = ElsherBillboards[obj]
                    local label = bill:FindFirstChildOfClass("TextLabel")
                    if label then
                        label.Text = data.displayName .. " [" .. data.health .. " HP]"
                    end
                end
            end
        end

