function createShotPlantBullet(position, direction)
    local bullet = Instance.new("Part")
    bullet.Name = "ShotPlantBullet"
    bullet.Anchored = false
    bullet.CanCollide = true
    bullet.Size = Vector3.new(0.5, 0.5, 0.5)
    bullet.Shape = Enum.PartType.Block
    bullet.Material = Enum.Material.Plastic
    bullet.BrickColor = BrickColor.new("Bright red")
    bullet.CFrame = CFrame.new(position, position + direction)
    local mesh = Instance.new("SpecialMesh")
    mesh.MeshId = "rbxassetid://2702173630"
    mesh.TextureId = "rbxassetid://2702173739"
    mesh.Scale = Vector3.new(3, 3, 3)
    mesh.Parent = bullet
    bullet.Parent = workspace
    local bv = Instance.new("BodyVelocity")
    bv.MaxForce = Vector3.new(1e6, 1e6, 1e6)
    bv.Velocity = direction * 200
    bv.Parent = bullet
    bullet.Touched:Connect(function(hit)
        if hit and hit.CanCollide then
            bullet:Destroy()
        end
    end)
    task.delay(5, function()
        if bullet and bullet.Parent then bullet:Destroy() end
    end)
end

function setupShotPlantForTool(tool)
    if not tool or not tool:IsA("Tool") then return end
    if not tool:GetAttribute("IsGun") then return end
    pcall(function()
        if WindUI then
            WindUI:Notify({ Title = "Shot Plant", Content = tool.Name .. " is compatible with the bullet modifier.", Duration = 3 })
        end
    end)
    local clip = tool:GetAttribute("ClipCurrent")
    if clip then
        shotPlantClipValue = tonumber(clip) or 0
    else
        shotPlantClipValue = 0
    end
    if shotPlantAttributeConnection then shotPlantAttributeConnection:Disconnect() end
    shotPlantAttributeConnection = tool:GetAttributeChangedSignal("ClipCurrent"):Connect(function()
        if not Config.ShotPlantEnabled then return end
        local newClip = tool:GetAttribute("ClipCurrent")
        local newNum = tonumber(newClip) or 0
        if newNum < shotPlantClipValue then
            local char = LocalPlayer.Character
            if char then
                local hrp = char:FindFirstChild("HumanoidRootPart")
                if hrp then
                    local pos = hrp.Position + Vector3.new(0, 1.5, 0) + Camera.CFrame.LookVector * 2
                    local dir = Camera.CFrame.LookVector
                    createShotPlantBullet(pos, dir)
                end
            end
        end
        shotPlantClipValue = newNum
    end)
end

function enableShotPlant(state)
    if state then
        Config.ShotPlantEnabled = true
        local char = LocalPlayer.Character
        if char then
            local tool = char:FindFirstChildOfClass("Tool")
            if tool then
                setupShotPlantForTool(tool)
            end
            if shotPlantToolAddedConnection then shotPlantToolAddedConnection:Disconnect() end
            shotPlantToolAddedConnection = char.ChildAdded:Connect(function(child)
                if child:IsA("Tool") and Config.ShotPlantEnabled then
                    setupShotPlantForTool(child)
                end
            end)
            if shotPlantToolRemovedConnection then shotPlantToolRemovedConnection:Disconnect() end
            shotPlantToolRemovedConnection = char.ChildRemoved:Connect(function(child)
                if child:IsA("Tool") then
                    if shotPlantAttributeConnection then
                        shotPlantAttributeConnection:Disconnect()
                        shotPlantAttributeConnection = nil
                    end
                    shotPlantClipValue = nil
                end
            end)
        end
        if shotPlantCharacterAddedConnection then shotPlantCharacterAddedConnection:Disconnect() end
        shotPlantCharacterAddedConnection = LocalPlayer.CharacterAdded:Connect(function()
            if Config.ShotPlantEnabled then
                if shotPlantAttributeConnection then shotPlantAttributeConnection:Disconnect(); shotPlantAttributeConnection = nil end
                shotPlantClipValue = nil
                local char = LocalPlayer.Character
                if char then
                    local tool = char:FindFirstChildOfClass("Tool")
