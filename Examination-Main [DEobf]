animatorIdleTrack = nil
animatorWalkTrack = nil
animatorRunTrack = nil
animatorLastState = nil

function filterAnimNames(endPatterns)
    local result = {}
    for name, id in pairs(toggleAnims) do
        local lower = name:lower()
        for _, pattern in ipairs(endPatterns) do
            if lower:sub(-#pattern) == pattern then
                table.insert(result, name)
                break
            end
        end
    end
    return result
end

idleAnimNames = filterAnimNames({"idle", "idle (old)"})
walkAnimNames = filterAnimNames({"walk", "walk (old)"})
runAnimNames = filterAnimNames({"run", "run (old)"})

function stopAllAnimatorTracks()
    if animatorIdleTrack then animatorIdleTrack:Stop(); animatorIdleTrack = nil end
    if animatorWalkTrack then animatorWalkTrack:Stop(); animatorWalkTrack = nil end
    if animatorRunTrack then animatorRunTrack:Stop(); animatorRunTrack = nil end
end

function applyAnimatorState()
    if blockAnimations then
        stopAllAnimatorTracks()
        return
    end
    if Config.FakeDeath then
        stopAllAnimatorTracks()
        return
    end
    if not Config.AnimatorEnabled then
        stopAllAnimatorTracks()
        return
    end
    local char = LocalPlayer.Character
    if not char then return end
    local humanoid = char:FindFirstChildOfClass("Humanoid")
    if not humanoid or humanoid.Health <= 0 then return end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    local velocity = hrp.Velocity
    local horizontalVel = Vector3.new(velocity.X, 0, velocity.Z)
    local speed = horizontalVel.Magnitude
    local newState
    if isShiftHeld and speed > 2 then
        newState = "run"
    elseif speed > 0.5 then
        newState = "walk"
    else
        newState = "idle"
    end
    if newState ~= animatorLastState then
        animatorLastState = newState
        stopAllAnimatorTracks()
        if newState == "idle" and Config.AnimatorIdleAnimName then
            animatorIdleTrack = playAnimationOnHumanoid(toggleAnims[Config.AnimatorIdleAnimName], true)
        elseif newState == "walk" and Config.AnimatorWalkAnimName then
            animatorWalkTrack = playAnimationOnHumanoid(toggleAnims[Config.AnimatorWalkAnimName], true)
        elseif newState == "run" and Config.AnimatorRunAnimName then
            animatorRunTrack = playAnimationOnHumanoid(toggleAnims[Config.AnimatorRunAnimName], true)
        end
    end
end

