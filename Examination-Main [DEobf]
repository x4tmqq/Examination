function applyInstantProximity()
    for _, v in ipairs(Workspace:GetDescendants()) do
        if v:IsA("ProximityPrompt") then
            v.HoldDuration = 0
        end
    end
end

function setupInstantProximity()
    if InstantProximityConnection then InstantProximityConnection:Disconnect() end
    if Config.InstantProximityPrompt then
        applyInstantProximity()
        InstantProximityConnection = Workspace.DescendantAdded:Connect(function(desc)
            if Config.InstantProximityPrompt and desc:IsA("ProximityPrompt") then
                desc.HoldDuration = 0
            end
        end)
    end
end

function autoCompleteProximity()
    if not Config.AutoCompleteProximityPrompt then
        if AutoCompletePromptConnection then
            AutoCompletePromptConnection:Disconnect()
            AutoCompletePromptConnection = nil
        end
        return
    end
    if AutoCompletePromptConnection then AutoCompletePromptConnection:Disconnect() end
    AutoCompletePromptConnection = ProximityPromptService.PromptShown:Connect(function(prompt)
        if not Config.AutoCompleteProximityPrompt then return end
        if not prompt.Enabled then return end
        VirtualInputManager:SendKeyEvent(true, Enum.KeyCode.E, false, game)
        prompt.PromptHidden:Wait()
        VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.E, false, game)
    end)
end

function BreakGasmask()
    local playerGui = LocalPlayer:FindFirstChild("PlayerGui")
    if not playerGui then return false end
    local gasmaskGui = playerGui:FindFirstChild("Gasmask")
    if not gasmaskGui then return false end
    local maskHole = gasmaskGui:FindFirstChild("MaskHole")
    local glass = gasmaskGui:FindFirstChild("Glass")
    if maskHole then
        if maskHole:IsA("ImageLabel") then
            maskHole.ImageTransparency = 0
            maskHole.Visible = true
        elseif maskHole:IsA("Frame") then
            maskHole.Visible = true
            for _, child in pairs(maskHole:GetDescendants()) do
                if child:IsA("ImageLabel") then
                    child.ImageTransparency = 0
                    child.Visible = true
                end
            end
        end
    end
    local crackSound = Instance.new("Sound")
    crackSound.SoundId = "rbxassetid://632831227"
    crackSound.Volume = 1
    crackSound.Parent = gasmaskGui
    crackSound:Play()
    Debris:AddItem(crackSound, 3)
    if glass and glass:IsA("ImageLabel") then
        local originalTransparency = glass.ImageTransparency
        TweenService:Create(glass, TweenInfo.new(0.1), { ImageTransparency = 0.5 }):Play()
        task.wait(0.05)
        TweenService:Create(glass, TweenInfo.new(0.5), { ImageTransparency = originalTransparency }):Play()
    end
    return true
end

function showBloodVignette(show)
    local playerGui = LocalPlayer:FindFirstChild("PlayerGui")
    if not playerGui then return end
    local gui = playerGui:FindFirstChild("Gui")
    if not gui then return end
    local blood = gui:FindFirstChild("blood-vignette")
    if blood and blood:IsA("ImageLabel") then
        blood.Visible = show
        if show then
            blood.ImageTransparency = 0
        else
            blood.ImageTransparency = 1
        end
    end
end

function createRedTint()
    local cc = Lighting:FindFirstChild("InfectionRedTint")
    if not cc then
        cc = Instance.new("ColorCorrectionEffect")
        cc.Name = "InfectionRedTint"
        cc.Parent = Lighting
    end
    return cc
end

function playAnimationOnHumanoid(animId, looped, callback)
    local char = LocalPlayer.Character
    if not char then return nil end
    local humanoid = char:FindFirstChildOfClass("Humanoid")
    if not humanoid then return nil end
    local animator = humanoid:FindFirstChildOfClass("Animator") or Instance.new("Animator", humanoid)
    local anim = Instance.new("Animation")
    anim.AnimationId = animId
    local track = animator:LoadAnimation(anim)
    track.Looped = looped or false
    track:Play()
    if callback then
        track.Stopped:Connect(callback)
    end
    return track
end

