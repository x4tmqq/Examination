local function isPlayerCharacter(model)
    if not model or not model:IsA("Model") then return false end
    return Players:GetPlayerFromCharacter(model) ~= nil
end

local function isHumanoidModel(model)
    if not model or not model:IsA("Model") then return false end
    return model:FindFirstChildWhichIsA("Humanoid") ~= nil
end

local ExpandHitbox = false
local HitboxSize = 4
local ShootThroughShieldActive = false

local function applyToPart(part)
    if not part or not part:IsA("BasePart") then return end
    if part.Name ~= "Head" then return end

    local model = part.Parent
    -- Vérifie que c'est un NPC (ni joueur, ni personnage local)
    if isHumanoidModel(model) and not isPlayerCharacter(model) and model ~= LocalPlayer.Character then
        pcall(function()
            if ExpandHitbox then
                if not part:GetAttribute("OriginalSize") then
                    part:SetAttribute("OriginalSize", part.Size)
                end
                part.Size = Vector3.new(HitboxSize, HitboxSize, HitboxSize)
                part.CanCollide = false
                part.Transparency = 0.5
            else
                local originalSize = part:GetAttribute("OriginalSize")
                if originalSize then
                    part.Size = originalSize
                end
                part.CanCollide = true
                part.Transparency = 0
            end
        end)
    end
end

local function UpdateAllHitboxes()
    local allDescendants = Workspace:GetDescendants()
    for _, part in ipairs(allDescendants) do
        if part:IsA("BasePart") and part.Name == "Head" then
            local model = part.Parent
            if isHumanoidModel(model) and not isPlayerCharacter(model) and model ~= LocalPlayer.Character then
                if ExpandHitbox then
                    pcall(function()
                        if not part:GetAttribute("OriginalSize") then
                            part:SetAttribute("OriginalSize", part.Size)
                        end
                        part.Size = Vector3.new(HitboxSize, HitboxSize, HitboxSize)
                        part.CanCollide = false
                        part.Transparency = 0.5
                    end)
                else
                    local originalSize = part:GetAttribute("OriginalSize")
                    if originalSize then
                        part.Size = originalSize
                    end
                    part.CanCollide = true
                    part.Transparency = 0
                end
            end
        end
    end
end

local function UpdateAllShields()
    for _, obj in ipairs(workspace:GetDescendants()) do
        if obj.Name == "Shield" then
            for _, part in ipairs(obj:GetDescendants()) do
                if part:IsA("BasePart") then
                    if ShootThroughShieldActive then
                        part.CanCollide = false
                    else
                        part.CanCollide = true
                    end
                end
            end
        end
    end
end

local function watchNameChanges(part)
    if not part or not part:IsA("BasePart") then return end
    part:GetPropertyChangedSignal("Name"):Connect(function()
        applyToPart(part)
    end)
end

for _, desc in ipairs(Workspace:GetDescendants()) do
    applyToPart(desc)
    if desc:IsA("BasePart") then
        watchNameChanges(desc)
    end
end

Workspace.DescendantAdded:Connect(function(desc)
    applyToPart(desc)
    if desc:IsA("BasePart") then
        watchNameChanges(desc)
    end
end)

