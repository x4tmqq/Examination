local function resetFade(instance)
    for _, v in ipairs(instance:GetDescendants()) do
        if v:IsA("Frame") and v:GetAttribute("_cd_BackgroundTransparency") then v.BackgroundTransparency = v:GetAttribute("_cd_BackgroundTransparency")
        elseif (v:IsA("ImageLabel") or v:IsA("ImageButton")) then
            if v:GetAttribute("_cd_ImageTransparency") then v.ImageTransparency = v:GetAttribute("_cd_ImageTransparency") end
            if v:GetAttribute("_cd_BackgroundTransparency") then v.BackgroundTransparency = v:GetAttribute("_cd_BackgroundTransparency") end
        elseif (v:IsA("TextLabel") or v:IsA("TextButton") or v:IsA("TextBox")) then
            if v:GetAttribute("_cd_TextTransparency") then v.TextTransparency = v:GetAttribute("_cd_TextTransparency") end
            if v:GetAttribute("_cd_BackgroundTransparency") then v.BackgroundTransparency = v:GetAttribute("_cd_BackgroundTransparency") end
        elseif v:IsA("UIStroke") and v:GetAttribute("_cd_Transparency") then v.Transparency = v:GetAttribute("_cd_Transparency") end
    end
end

local function fadeOut(instance, duration)
    local info = TweenInfo.new(duration, Enum.EasingStyle.Linear, Enum.EasingDirection.Out)
    for _, v in ipairs(instance:GetDescendants()) do
        if v:IsA("Frame") then
            if not v:GetAttribute("_cd_BackgroundTransparency") then v:SetAttribute("_cd_BackgroundTransparency", v.BackgroundTransparency) end
            TweenService:Create(v, info, { BackgroundTransparency = 1 }):Play()
        elseif v:IsA("ImageLabel") or v:IsA("ImageButton") then
            if not v:GetAttribute("_cd_ImageTransparency") then v:SetAttribute("_cd_ImageTransparency", v.ImageTransparency) end
            if not v:GetAttribute("_cd_BackgroundTransparency") then v:SetAttribute("_cd_BackgroundTransparency", v.BackgroundTransparency) end
            TweenService:Create(v, info, { ImageTransparency = 1, BackgroundTransparency = 1 }):Play()
        elseif v:IsA("TextLabel") or v:IsA("TextButton") or v:IsA("TextBox") then
            if not v:GetAttribute("_cd_TextTransparency") then v:SetAttribute("_cd_TextTransparency", v.TextTransparency) end
            if not v:GetAttribute("_cd_BackgroundTransparency") then v:SetAttribute("_cd_BackgroundTransparency", v.BackgroundTransparency) end
            TweenService:Create(v, info, { TextTransparency = 1, BackgroundTransparency = 1 }):Play()
        elseif v:IsA("UIStroke") then
            if not v:GetAttribute("_cd_Transparency") then v:SetAttribute("_cd_Transparency", v.Transparency) end
            TweenService:Create(v, info, { Transparency = 1 }):Play()
        end
    end
end

local function getCooldownBar(name)
    local playerGui = LocalPlayer:FindFirstChild("PlayerGui")
    if not playerGui then return nil end
    local character = LocalPlayer.Character; local tool = character and character:FindFirstChildOfClass("Tool")
    if not tool then return nil end
    local screenGui = playerGui:FindFirstChild(tool.Name)
    if screenGui and screenGui:FindFirstChild("Data") and screenGui.Data:FindFirstChild("Cooldowns") and screenGui.Data.Cooldowns:FindFirstChild(name) then
        return screenGui.Data.Cooldowns[name]:FindFirstChild("Bar")
    end
    return nil
end

local function playCooldown(name, duration, progress)
    local currentCounter = CooldownCounter; local bar = getCooldownBar(name)
    if not bar then return end
    local container = getCooldownContainer(); local mainFrame = container and container:FindFirstChild(name)
    if mainFrame then resetFade(mainFrame) end
    if ActiveTweens[name] then ActiveTweens[name]:Cancel(); ActiveTweens[name] = nil end
    bar.AnchorPoint = Vector2.new(0, 1); bar.Position = UDim2.new(0, 0, 1, 0); bar.Size = UDim2.new(1, 0, math.clamp(progress or 0, 0, 1), 0); bar.Visible = true
    local tween = TweenService:Create(bar, TweenInfo.new(duration, Enum.EasingStyle.Linear, Enum.EasingDirection.Out), { Size = UDim2.new(1, 0, 1, 0) })
    ActiveTweens[name] = tween; 
    if container then setCooldownVisibility(name, true) end
    tween:Play()
    tween.Completed:Connect(function()
        if currentCounter ~= CooldownCounter or ActiveTweens[name] ~= tween then return end
        ActiveTweens[name] = nil; CooldownData[name] = nil
        if mainFrame then fadeOut(mainFrame, 0.2) end
        task.delay(0.2, function()
            if currentCounter ~= CooldownCounter then return end
            bar.Visible = false; 
            if container then setCooldownVisibility(name, false) end
            if mainFrame then resetFade(mainFrame) end
        end)
    end)
end

local function renderCooldown(name)
    local data = CooldownData[name]
    if not data then 
        local container = getCooldownContainer()
        if container then setCooldownVisibility(name, false) end
        return 
    end
    local currentTick = tick(); local remaining = data.finish - currentTick
    if remaining <= 0 then 
        CooldownData[name] = nil; 
        local container = getCooldownContainer()
        if container then setCooldownVisibility(name, false) end
        return 
    end
    playCooldown(name, remaining, data.duration > 0 and math.clamp((currentTick - data.start) / data.duration, 0, 1) or 0)
end

local function renderAllCooldowns()
    CooldownCounter = CooldownCounter + 1
    for k, v in pairs(ActiveTweens) do if v then v:Cancel() end; ActiveTweens[k] = nil end
    renderCooldown("Bash"); renderCooldown("Kick")
end

