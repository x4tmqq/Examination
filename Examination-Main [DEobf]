function isNPC(obj)
    if not obj:IsA("Model") then return false end
    if obj:IsA("Accessory") or obj:IsA("Tool") or obj:IsA("Hat") then return false end
    if isPlayerCharacter(obj) then return false end
    if obj == LocalPlayer.Character then return false end
    local humanoid = obj:FindFirstChildOfClass("Humanoid")
    if not humanoid then return false end
    if humanoid.Health <= 0 then return false end
    return true
end

function performCustomFinisher(target)
    if finisherActive then return end
    if not target or not isNPC(target) then return end
    local humanoid = target:FindFirstChildOfClass("Humanoid")
    if not humanoid or humanoid.Health > 50 then return end
    finisherActive = true
    blockAnimations = true
    local oldCamMode = LocalPlayer.CameraMode
    local oldZoom = LocalPlayer.CameraMaxZoomDistance
    LocalPlayer.CameraMode = Enum.CameraMode.Classic
    LocalPlayer.CameraMaxZoomDistance = 999
    local char = LocalPlayer.Character
    if char then
        local hum = char:FindFirstChildOfClass("Humanoid")
        if hum then
            local animator = hum:FindFirstChildOfClass("Animator")
            if animator then
                for _, track in pairs(animator:GetPlayingAnimationTracks()) do
                    track:Stop()
                end
            end
        end
    end
    local playerAnimId = "rbxassetid://112634711476303"
    local playerTrack = playAnimationOnHumanoid(playerAnimId, false)
    local victimAnimId = "rbxassetid://83991914102646"
    local victimAnimator = target:FindFirstChildOfClass("Humanoid") and target:FindFirstChildOfClass("Humanoid"):FindFirstChildOfClass("Animator")
    if not victimAnimator then
        victimAnimator = Instance.new("Animator", target:FindFirstChildOfClass("Humanoid"))
    end
    local victimAnim = Instance.new("Animation")
    victimAnim.AnimationId = victimAnimId
    local victimTrack = victimAnimator:LoadAnimation(victimAnim)
    victimTrack:Play()
    task.wait(5)
    local success = false
    if humanoid and humanoid.Health <= 0 then
        success = true
    end
    if success then
        if WindUI then WindUI:Notify({ Title = "Finisher", Content = "Finisher successful!", Duration = 3 }) end
    else
        if WindUI then WindUI:Notify({ Title = "Finisher", Content = "Sorry :( Finisher failed.", Duration = 3 }) end
    end
    if playerTrack then playerTrack:Stop() end
    if victimTrack then victimTrack:Stop() end
    LocalPlayer.CameraMode = oldCamMode
    LocalPlayer.CameraMaxZoomDistance = oldZoom
    blockAnimations = false
    finisherActive = false
end

function onAttack()
    if not Config.GAttackEnabled then return end
    if blockAnimations then return end
    local currentTick = tick()
    if not Config.BypassCombatCooldowns then
        if currentTick - LastAttackTick < 0.1 then return end
    end
    LastAttackTick = currentTick
    local character = LocalPlayer.Character
    if not character then return end
    local tool = character:FindFirstChildOfClass("Tool")
    local isHoldingValid = tool and ValidCombatTools[tool.Name] or false
    if not isHoldingValid then return end
    local char2 = LocalPlayer.Character
    if not char2 then return end
    local timeDiff = currentTick - LastSpecialAttackTick
    if IsSpecialAttackActive and (Config.BypassCombatCooldowns or timeDiff <= 2) then
        if PunchEvent then PunchEvent:FireServer() end
        return
    end
    if not Config.BypassCombatCooldowns then
        if timeDiff < 5.1 then return end
    end
    LastSpecialAttackTick = currentTick
    IsSpecialAttackActive = true
    task.delay(2, function()
        if IsSpecialAttackActive and tick() - LastSpecialAttackTick >= 2 then
            IsSpecialAttackActive = false
        end
    end)
    if CurrentAnimTrack and CurrentAnimTrack.IsPlaying and not Config.BypassCombatCooldowns then
        return
    end
    local equippedTool = char2:FindFirstChildOfClass("Tool")
    CurrentAnimTrack = loadAnimation(char2, equippedTool and equippedTool.Name or "Default")
    if not CurrentAnimTrack then
        if PunchEvent then PunchEvent:FireServer() end
        return
    end
    CurrentAnimTrack:Play()
    playSwingSound(char2)
    CurrentAnimTrack.Stopped:Connect(function()
        task.wait(0.1)
        CurrentAnimTrack = nil
    end)
    if PunchEvent then PunchEvent:FireServer() end
    if Config.CustomFinisherEnabled then
        task.delay(0.2, function()
            local myChar = LocalPlayer.Character
            if not myChar then return end
            local myRoot = myChar:FindFirstChild("HumanoidRootPart")
            if not myRoot then return end
            local radius = 10
            local closestNPC = nil
            local closestDist = math.huge
            for _, obj in ipairs(workspace:GetDescendants()) do
                if isNPC(obj) then
                    local root = obj:FindFirstChild("HumanoidRootPart") or obj:FindFirstChildWhichIsA("BasePart")
                    if root then
                        local dist = (root.Position - myRoot.Position).Magnitude
                        if dist <= radius and dist < closestDist then
                            local hum = obj:FindFirstChildOfClass("Humanoid")
                            if hum and hum.Health <= 50 then
                                closestNPC = obj
                                closestDist = dist
                            end
                        end
                    end
                end
            end
            if closestNPC then
                performCustomFinisher(closestNPC)
            end
        end)
    end
end

