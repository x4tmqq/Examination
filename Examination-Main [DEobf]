    if not tool then return nil end
    local screenGui = playerGui:FindFirstChild(tool.Name)
    if screenGui and screenGui:FindFirstChild("Data") and screenGui.Data:FindFirstChild("Cooldowns") and screenGui.Data.Cooldowns:FindFirstChild(name) then
        return screenGui.Data.Cooldowns[name]:FindFirstChild("Bar")
    end
    return nil
end

function playCooldown(name, duration, progress)
    local currentCounter = CooldownCounter
    local bar = getCooldownBar(name)
    if not bar then return end
    local container = getCooldownContainer()
    local mainFrame = container and container:FindFirstChild(name)
    if mainFrame then resetFade(mainFrame) end
    if ActiveTweens[name] then ActiveTweens[name]:Cancel(); ActiveTweens[name] = nil end
    bar.AnchorPoint = Vector2.new(0, 1)
    bar.Position = UDim2.new(0, 0, 1, 0)
    bar.Size = UDim2.new(1, 0, math.clamp(progress or 0, 0, 1), 0)
    bar.Visible = true
    local tween = TweenService:Create(bar, TweenInfo.new(duration, Enum.EasingStyle.Linear, Enum.EasingDirection.Out), { Size = UDim2.new(1, 0, 1, 0) })
    ActiveTweens[name] = tween
    if container then setCooldownVisibility(name, true) end
    tween:Play()
    tween.Completed:Connect(function()
        if currentCounter ~= CooldownCounter or ActiveTweens[name] ~= tween then return end
        ActiveTweens[name] = nil
        CooldownData[name] = nil
        if mainFrame then fadeOut(mainFrame, 0.2) end
        task.delay(0.2, function()
            if currentCounter ~= CooldownCounter then return end
            bar.Visible = false
            if container then setCooldownVisibility(name, false) end
            if mainFrame then resetFade(mainFrame) end
        end)
    end)
end

function renderCooldown(name)
    local data = CooldownData[name]
    if not data then
        local container = getCooldownContainer()
        if container then setCooldownVisibility(name, false) end
        return
    end
    local currentTick = tick()
    local remaining = data.finish - currentTick
    if remaining <= 0 then
        CooldownData[name] = nil
        local container = getCooldownContainer()
        if container then setCooldownVisibility(name, false) end
        return
    end
    playCooldown(name, remaining, data.duration > 0 and math.clamp((currentTick - data.start) / data.duration, 0, 1) or 0)
end

function renderAllCooldowns()
    CooldownCounter = CooldownCounter + 1
    for k, v in pairs(ActiveTweens) do if v then v:Cancel() end; ActiveTweens[k] = nil end
    renderCooldown("Bash")
    renderCooldown("Kick")
end

