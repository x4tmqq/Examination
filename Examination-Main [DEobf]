RunService.RenderStepped:Connect(function()
    if Config.UnlockThirdPerson then
        if LocalPlayer.CameraMode ~= Enum.CameraMode.Classic then
            LocalPlayer.CameraMode = Enum.CameraMode.Classic
        end
        if LocalPlayer.CameraMaxZoomDistance < 999 then
            LocalPlayer.CameraMaxZoomDistance = 999
        end
    else
        if LocalPlayer.CameraMode ~= Enum.CameraMode.LockFirstPerson then
            LocalPlayer.CameraMode = Enum.CameraMode.LockFirstPerson
        end
        if LocalPlayer.CameraMaxZoomDistance > 50 then
            LocalPlayer.CameraMaxZoomDistance = 50
        end
    end
    local myChar = LocalPlayer.Character
    local myHrp = myChar and myChar:FindFirstChild("HumanoidRootPart")
    if not myHrp then return end
    for _, player in pairs(Players:GetPlayers()) do
        if player ~= LocalPlayer then
            local char = player.Character
            local phrp = char and char:FindFirstChild("HumanoidRootPart")
            local phum = char and char:FindFirstChildOfClass("Humanoid")
            if phrp and phum then
                local distance = (myHrp.Position - phrp.Position).Magnitude
                local isFriend = LocalPlayer:IsFriendsWith(player.UserId)
                local hlToggle = isFriend and Config.HighlightFriends or Config.HighlightPlayer
                local hpToggle = isFriend and Config.HealthFriends or Config.HealthPlayer
                local trToggle = isFriend and Config.TracerFriends or Config.TracerPlayer
                local color = isFriend and Config.ColorFriends or Config.ColorPlayer
                if distance <= Config.MaxDistance then
                    local hl = char:FindFirstChild("SentinelHL")
                    if hlToggle then
                        if not hl then
                            hl = Instance.new("Highlight", char)
                            hl.Name = "SentinelHL"
                        end
                        hl.FillColor = color
                        hl.FillTransparency = Config.HLFillTrans
                        hl.OutlineTransparency = Config.HLOutlineTrans
                    elseif hl then hl:Destroy() end
                    local bgui = phrp:FindFirstChild("SentinelHP")
                    if hpToggle then
                        if not bgui then
                            bgui = Instance.new("BillboardGui", phrp)
                            bgui.Name = "SentinelHP"
                            bgui.Size = UDim2.new(0, 150, 0, 30)
                            bgui.AlwaysOnTop = true
                            bgui.StudsOffset = Vector3.new(0, 3, 0)
                            local text = Instance.new("TextLabel", bgui)
                            text.Size = UDim2.new(1,0,1,0)
                            text.BackgroundTransparency = 1
                            text.TextStrokeTransparency = 0
                            text.Font = Enum.Font.SourceSansBold
                            text.TextSize = 13
                        end
                        if bgui and bgui.TextLabel then
                            bgui.TextLabel.TextColor3 = color
                            bgui.TextLabel.Text = string.format("%s [%d HP]", player.Name, math.round(phum.Health))
                        end
                    elseif bgui then bgui:Destroy() end
                    local line = getTracer(player.UserId)
                    if line then
                        if trToggle then
                            local vector, onScreen = Camera:WorldToViewportPoint(phrp.Position)
                            if onScreen then
                                line.From = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y)
                                line.To = Vector2.new(vector.X, vector.Y)
                                line.Color = color
                                line.Visible = true
                            else line.Visible = false end
                        else line.Visible = false end
                    end
                else
                    if char:FindFirstChild("SentinelHL") then char.SentinelHL:Destroy() end
                    if phrp:FindFirstChild("SentinelHP") then phrp.SentinelHP:Destroy() end
                    local line = tracerCache[player.UserId]
                    if line then line.Visible = false end
                end
            end
        end
    end
    for i = #CachedMobs, 1, -1 do
        local obj = CachedMobs[i]
        if obj and obj.Parent then
            if obj == myChar or obj == LocalPlayer.Character or obj.Name == LocalPlayer.Name or Players:GetPlayerFromCharacter(obj) then
                if obj:FindFirstChild("SentinelMobHL") then obj.SentinelMobHL:Destroy() end
                local badHrp = obj:FindFirstChild("HumanoidRootPart")
                if badHrp and badHrp:FindFirstChild("SentinelMobHP") then badHrp.SentinelMobHP:Destroy() end
                local badId = obj:GetDebugId()
                if tracerCache[badId] then tracerCache[badId].Visible = false end
                table.remove(CachedMobs, i)
                continue
            end
            local mhrp = obj:FindFirstChild("HumanoidRootPart")
            local mhum = obj:FindFirstChildOfClass("Humanoid")
            if mhrp and mhum then
                local distance = (myHrp.Position - mhrp.Position).Magnitude
                local mobId = obj:GetDebugId()
                if distance <= Config.MaxDistance and mhum.Health > 0 then
                    local hl = obj:FindFirstChild("SentinelMobHL")
                    if Config.HighlightMobs then
                        if not hl then
                            hl = Instance.new("Highlight", obj)
                            hl.Name = "SentinelMobHL"
                        end
                        hl.FillColor = Config.ColorMobs
                        hl.FillTransparency = Config.HLFillTrans
                        hl.OutlineTransparency = Config.HLOutlineTrans
                    elseif hl then hl:Destroy() end
                    local bgui = mhrp:FindFirstChild("SentinelMobHP")
                    if Config.HealthMobs then
                        if not bgui then
                            bgui = Instance.new("BillboardGui", mhrp)
                            bgui.Name = "SentinelMobHP"
                            bgui.Size = UDim2.new(0, 150, 0, 30)
                            bgui.AlwaysOnTop = true
                            bgui.StudsOffset = Vector3.new(0, 3, 0)
                            local text = Instance.new("TextLabel", bgui)
                            text.Size = UDim2.new(1,0,1,0)
                            text.BackgroundTransparency = 1
                            text.TextStrokeTransparency = 0
                            text.Font = Enum.Font.SourceSansBold
                            text.TextSize = 13
                        end
                        if bgui and bgui.TextLabel then
                            bgui.TextLabel.TextColor3 = Config.ColorMobs
                            bgui.TextLabel.Text = string.format("%s [%d HP]", obj.Name, math.round(mhum.Health))
                        end
                    elseif bgui then bgui:Destroy() end
                    local line = getTracer(mobId)
                    if line then
                        if Config.TracerMobs then
                            local vector, onScreen = Camera:WorldToViewportPoint(mhrp.Position)
                            if onScreen then
                                line.From = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y)
                                line.To = Vector2.new(vector.X, vector.Y)
                                line.Color = Config.ColorMobs
                                line.Visible = true
                            else line.Visible = false end
                        else line.Visible = false end
                    end
                else
                    if obj:FindFirstChild("SentinelMobHL") then obj.SentinelMobHL:Destroy() end
                    if mhrp and mhrp:FindFirstChild("SentinelMobHP") then mhrp.SentinelMobHP:Destroy() end
                    local line = tracerCache[mobId]
                    if line then line.Visible = false end
                end
            end
        else
            table.remove(CachedMobs, i)
        end
    end
end)

