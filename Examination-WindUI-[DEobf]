                local hpToggle = isFriend and Config.HealthFriends or Config.HealthPlayer
                local trToggle = isFriend and Config.TracerFriends or Config.TracerPlayer
                local color = isFriend and Config.ColorFriends or Config.ColorPlayer
                if distance <= Config.MaxDistance then
                    local hl = char:FindFirstChild("SentinelHL")
                    if hlToggle then
                        if not hl then
                            hl = Instance.new("Highlight", char)
                            hl.Name = "SentinelHL"
                        end
                        hl.FillColor = color
                        hl.FillTransparency = Config.HLFillTrans
                        hl.OutlineTransparency = Config.HLOutlineTrans
                    elseif hl then hl:Destroy() end
                    local bgui = phrp:FindFirstChild("SentinelHP")
                    if hpToggle then
                        if not bgui then
                            bgui = Instance.new("BillboardGui", phrp)
                            bgui.Name = "SentinelHP"
                            bgui.Size = UDim2.new(0, 150, 0, 30)
                            bgui.AlwaysOnTop = true
                            bgui.StudsOffset = Vector3.new(0, 3, 0)
