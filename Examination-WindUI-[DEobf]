local function filterAnimNames(endPatterns)
    local result = {}
    for name, id in pairs(toggleAnims) do
        local lower = name:lower()
        for _, pattern in ipairs(endPatterns) do
            if lower:sub(-#pattern) == pattern then
                table.insert(result, name)
                break
            end
        end
    end
    return result
end

