local function resetFade(instance)
    for _, v in ipairs(instance:GetDescendants()) do
        if v:IsA("Frame") and v:GetAttribute("_cd_BackgroundTransparency") then
            v.BackgroundTransparency = v:GetAttribute("_cd_BackgroundTransparency")
        elseif (v:IsA("ImageLabel") or v:IsA("ImageButton")) then
            if v:GetAttribute("_cd_ImageTransparency") then v.ImageTransparency = v:GetAttribute("_cd_ImageTransparency") end
            if v:GetAttribute("_cd_BackgroundTransparency") then v.BackgroundTransparency = v:GetAttribute("_cd_BackgroundTransparency") end
        elseif (v:IsA("TextLabel") or v:IsA("TextButton") or v:IsA("TextBox")) then
            if v:GetAttribute("_cd_TextTransparency") then v.TextTransparency = v:GetAttribute("_cd_TextTransparency") end
            if v:GetAttribute("_cd_BackgroundTransparency") then v.BackgroundTransparency = v:GetAttribute("_cd_BackgroundTransparency") end
        elseif v:IsA("UIStroke") and v:GetAttribute("_cd_Transparency") then
            v.Transparency = v:GetAttribute("_cd_Transparency")
        end
    end
end

local function fadeOut(instance, duration)
    local info = TweenInfo.new(duration, Enum.EasingStyle.Linear, Enum.EasingDirection.Out)
    for _, v in ipairs(instance:GetDescendants()) do
        if v:IsA("Frame") then
            if not v:GetAttribute("_cd_BackgroundTransparency") then v:SetAttribute("_cd_BackgroundTransparency", v.BackgroundTransparency) end
            TweenService:Create(v, info, { BackgroundTransparency = 1 }):Play()
        elseif v:IsA("ImageLabel") or v:IsA("ImageButton") then
            if not v:GetAttribute("_cd_ImageTransparency") then v:SetAttribute("_cd_ImageTransparency", v.ImageTransparency) end
            if not v:GetAttribute("_cd_BackgroundTransparency") then v:SetAttribute("_cd_BackgroundTransparency", v.BackgroundTransparency) end
            TweenService:Create(v, info, { ImageTransparency = 1, BackgroundTransparency = 1 }):Play()
        elseif v:IsA("TextLabel") or v:IsA("TextButton") or v:IsA("TextBox") then
            if not v:GetAttribute("_cd_TextTransparency") then v:SetAttribute("_cd_TextTransparency", v.TextTransparency) end
            if not v:GetAttribute("_cd_BackgroundTransparency") then v:SetAttribute("_cd_BackgroundTransparency", v.BackgroundTransparency) end
            TweenService:Create(v, info, { TextTransparency = 1, BackgroundTransparency = 1 }):Play()
        elseif v:IsA("UIStroke") then
            if not v:GetAttribute("_cd_Transparency") then v:SetAttribute("_cd_Transparency", v.Transparency) end
            TweenService:Create(v, info, { Transparency = 1 }):Play()
        end
    end
end

