local function deleteAllDoors()
    local gameDoors = workspace:FindFirstChild("GameDoors")
    if not gameDoors then
        pcall(function() if WindUI then WindUI:Notify({ Title = "Error", Content = "GameDoors not found", Duration = 3 }) end end)
        return
    end
    local count = 0
    for _, gen in ipairs(gameDoors:GetChildren()) do
        if gen.Name:match("Generator%d") then
            local doorsToOpen = gen:FindFirstChild("DoorsToOpen")
            if doorsToOpen then
                doorsToOpen:Destroy()
                count = count + 1
            end
        end
    end
    pcall(function() if WindUI then WindUI:Notify({ Title = "Success", Content = "Deleted "..count.." DoorsToOpen folder(s)", Duration = 3 }) end end)
end

