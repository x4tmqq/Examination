local function toggleFakeInjured()
    if Config.FakeInjured then
        local char = LocalPlayer.Character
        if not char then return end
        local humanoid = char:FindFirstChildOfClass("Humanoid")
        if not humanoid then return end
        if not FakeInjuredTrack then
            local animator = humanoid:FindFirstChildOfClass("Animator") or Instance.new("Animator", humanoid)
            local animation = Instance.new("Animation")
            animation.AnimationId = "rbxassetid://94302036679429"
            FakeInjuredTrack = animator:LoadAnimation(animation)
            FakeInjuredTrack.Looped = true
        end
    else
        if FakeInjuredTrack then
            FakeInjuredTrack:Stop()
            FakeInjuredTrack = nil
        end
    end
end

RunService.Heartbeat:Connect(function()
    if not Config.FakeInjured then
        if FakeInjuredTrack and FakeInjuredTrack.IsPlaying then
            FakeInjuredTrack:Stop()
        end
        return
    end
    local char = LocalPlayer.Character
    if not char then return end
    local humanoid = char:FindFirstChildOfClass("Humanoid")
    if not humanoid or humanoid.Health <= 0 then
        if FakeInjuredTrack and FakeInjuredTrack.IsPlaying then
            FakeInjuredTrack:Stop()
        end
        return
    end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hrp then
        if FakeInjuredTrack and FakeInjuredTrack.IsPlaying then
            FakeInjuredTrack:Stop()
        end
        return
    end
    local velocity = hrp.Velocity
    local horizontalVelocity = Vector3.new(velocity.X, 0, velocity.Z)
    local isIdle = horizontalVelocity.Magnitude < 0.5 and humanoid:GetState() ~= Enum.HumanoidStateType.Jumping and humanoid:GetState() ~= Enum.HumanoidStateType.Freefall
    
    if isIdle then
        if FakeInjuredTrack and not FakeInjuredTrack.IsPlaying then
            FakeInjuredTrack:Play()
        end
    else
        if FakeInjuredTrack and FakeInjuredTrack.IsPlaying then
            FakeInjuredTrack:Stop()
        end
    end
end)

local fakeDeathBV = nil
local fakeDeathBP = nil

local function toggleFakeDeath()
    local character = LocalPlayer.Character
    if not character then return end
    local humanoid = character:FindFirstChildOfClass("Humanoid")
    if not humanoid then return end
    if Config.FakeDeath then
        if fakeDeathBV then fakeDeathBV:Destroy(); fakeDeathBV = nil end
        if fakeDeathBP then fakeDeathBP:Destroy(); fakeDeathBP = nil end

        local animator = humanoid:FindFirstChildOfClass("Animator") or Instance.new("Animator", humanoid)
        local animation = Instance.new("Animation")
        animation.AnimationId = "rbxassetid://114023816208972"
        FakeDeathAnimTrack = animator:LoadAnimation(animation)
        FakeDeathAnimTrack.Looped = true
        FakeDeathAnimTrack:Play()
        humanoid.PlatformStand = true
        humanoid.WalkSpeed = 0
        humanoid.JumpPower = 0

        local hrp = character:FindFirstChild("HumanoidRootPart")
        if hrp then
            fakeDeathBV = Instance.new("BodyVelocity")
            fakeDeathBV.MaxForce = Vector3.new(1e6, 1e6, 1e6)
            fakeDeathBV.Velocity = Vector3.new(0, 0, 0)
            fakeDeathBV.Parent = hrp

            fakeDeathBP = Instance.new("BodyPosition")
            fakeDeathBP.MaxForce = Vector3.new(1e6, 1e6, 1e6)
            fakeDeathBP.Position = hrp.Position + Vector3.new(0, 1, 0)
            fakeDeathBP.Parent = hrp
        end
    else
        if FakeDeathAnimTrack then FakeDeathAnimTrack:Stop(); FakeDeathAnimTrack = nil end
        humanoid.PlatformStand = false
        humanoid.WalkSpeed = 9
        humanoid.JumpPower = 50
        if fakeDeathBV then fakeDeathBV:Destroy(); fakeDeathBV = nil end
        if fakeDeathBP then fakeDeathBP:Destroy(); fakeDeathBP = nil end
    end
end

local function suicideWithAnimation()
    local char = LocalPlayer.Character
    if not char then return end
    local humanoid = char:FindFirstChildOfClass("Humanoid")
    if not humanoid then return end
    local animator = humanoid:FindFirstChildOfClass("Animator") or Instance.new("Animator", humanoid)
    local anim = Instance.new("Animation")
    anim.AnimationId = "rbxassetid://82480275101558"
    local track = animator:LoadAnimation(anim)
    track:Play()
    track.Stopped:Wait()
    humanoid.Health = 0
end

