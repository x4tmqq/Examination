        tween.Completed:Connect(function()
            label:Destroy()
        end)
    end
end

local function stopInfection()
    InfectionActive = false
    infectionIsRunning = false
    showBloodVignette(false)
    local cc = Lighting:FindFirstChild("InfectionRedTint")
    if cc then cc:Destroy() end
    local effectsGui = LocalPlayer.PlayerGui:FindFirstChild("InfectionEffectsGui")
    if effectsGui then effectsGui:Destroy() end
    if InfectionCleanupFunctions then
        for _, func in ipairs(InfectionCleanupFunctions) do
            pcall(func)
        end
        InfectionCleanupFunctions = {}
    end
    local tracks = {infectionInjuredTrack, infectionHeadShakeTrack, infectionCoughTrack, infectionUnstableTrack,
                    infectionFallTrack, infectionLurkerTrack, infectionIdleTrack, infectionWalkTrack, infectionRunTrack}
    for _, t in ipairs(tracks) do
        if t then t:Stop(); t = nil end
    end
    infectionTransformDone = false
    infectionCurrentState = nil
    local char = LocalPlayer.Character
    if char then
        local hum = char:FindFirstChildOfClass("Humanoid")
        if hum then
            hum.PlatformStand = false
            hum.WalkSpeed = Config.SpeedHackEnabled and Config.WalkSpeedValue or 9
            hum.JumpPower = Config.JumpPowerEnabled and Config.JumpPowerValue or 50
            local animator = hum:FindFirstChildOfClass("Animator")
            if animator then
                for _, track in pairs(animator:GetPlayingAnimationTracks()) do
                    track:Stop()
                end
            end
        end
        local hrp = char:FindFirstChild("HumanoidRootPart")
        if hrp then
            hrp.Anchored = false
        end
        local clientScripts = char:FindFirstChild("ClientScripts")
        if clientScripts then
            local stagger = clientScripts:FindFirstChild("Stagger")
            if stagger then stagger.Disabled = not Config.StaggerEnabled end
        end
    end
end

local function startInfectionSequence(infectionType)
    if not canInfect then
        pcall(function()
            if WindUI then WindUI:Notify({ Title = "Infection", Content = "You must respawn before starting a new infection.", Duration = 3 }) end
        end)
        return
    end
    if InfectionActive then return end
    if infectionType ~= "Controllable" and infectionType ~= "NonControllable" then
        infectionType = "Controllable"
    end
    canInfect = false
    InfectionActive = true
    infectionIsRunning = true
    InfectionMode = infectionType

    BreakGasmask()
    showBloodVignette(true)

    local char = LocalPlayer.Character
    if not char then InfectionActive = false; infectionIsRunning = false; canInfect = true; return end
    local humanoid = char:FindFirstChildOfClass("Humanoid")
    if not humanoid then InfectionActive = false; infectionIsRunning = false; canInfect = true; return end

    humanoid.Health = 1

    infectionInjuredTrack = playAnimationOnHumanoid(INFECTION_ANIM_INJURED, true)
    infectionHeadShakeTrack = playAnimationOnHumanoid(INFECTION_ANIM_HEAD_SHAKE, true)

    local redTint = createRedTint()
    redTint.TintColor = Color3.fromRGB(255, 255, 255)

    local startTime = tick()
    local coughTimer = tick()
    local redStart = 40
    local demonStart = 45
    local transformTime = 60

    local function grand2Loop()
        while infectionIsRunning and humanoid and humanoid.Health > 0 do
            local elapsed = tick() - startTime

            if tick() - coughTimer >= 10 and elapsed < transformTime then
                coughTimer = tick()
                if infectionCoughTrack then infectionCoughTrack:Stop() end
                infectionCoughTrack = playAnimationOnHumanoid(INFECTION_ANIM_COUGH, false)
                local sound = Instance.new("Sound")
                sound.SoundId = "rbxassetid://93090593281658"
                sound.Volume = 1
                sound.Parent = char
                sound:Play()
                Debris:AddItem(sound, 2)
            end

            if not infectionUnstableTrack or not infectionUnstableTrack.IsPlaying then
                if infectionUnstableTrack then infectionUnstableTrack:Stop() end
                infectionUnstableTrack = playAnimationOnHumanoid(INFECTION_ANIM_UNSTABLE, true)
            end

            if elapsed >= redStart then
                local progress = math.min((elapsed - redStart) / 30, 1)
                redTint.TintColor = Color3.fromRGB(255, 255 - math.floor(progress * 255), 255 - math.floor(progress * 255))
            end

            if elapsed >= demonStart then
                spawnDemonicSymbol(true)
            end

            if elapsed >= transformTime then
                break
            end

            task.wait(0.5)
        end
    end

    task.spawn(grand2Loop)

    task.wait(transformTime)

    if not infectionIsRunning or not humanoid or humanoid.Health <= 0 then
        stopInfection()
        canInfect = true
        return
    end

    if infectionCoughTrack then infectionCoughTrack:Stop(); infectionCoughTrack = nil end
    if infectionUnstableTrack then infectionUnstableTrack:Stop(); infectionUnstableTrack = nil end
    if infectionInjuredTrack then infectionInjuredTrack:Stop(); infectionInjuredTrack = nil end
    if infectionHeadShakeTrack then infectionHeadShakeTrack:Stop(); infectionHeadShakeTrack = nil end

    if InfectionMode == "Controllable" then
        infectionFallTrack = playAnimationOnHumanoid(INFECTION_ANIM_FALL1, false, function()
            if infectionIsRunning then
                if infectionLurkerTrack then infectionLurkerTrack:Stop() end
                infectionLurkerTrack = playAnimationOnHumanoid(INFECTION_ANIM_LURKER_AWAKE, false, function()
                    local hrp = char:FindFirstChild("HumanoidRootPart")
                    if hrp then hrp.Anchored = false end
                    humanoid.PlatformStand = false
                    humanoid.WalkSpeed = 9
                    humanoid.JumpPower = 50
                    infectionTransformDone = true
                    infectionCurrentState = nil

                    local function stateMachine()
                        while infectionIsRunning and humanoid and humanoid.Health > 0 do
                            local hrp = char:FindFirstChild("HumanoidRootPart")
                            if hrp then
                                local velocity = hrp.Velocity
                                local horizontalVel = Vector3.new(velocity.X, 0, velocity.Z)
                                local speed = horizontalVel.Magnitude
                                local newState
                                if isShiftHeld and speed > 2 then
                                    newState = "run"
                                elseif speed > 0.5 then
                                    newState = "walk"
                                else
                                    newState = "idle"
                                end
                                if newState ~= infectionCurrentState then
                                    infectionCurrentState = newState
                                    if infectionIdleTrack then infectionIdleTrack:Stop(); infectionIdleTrack = nil end
                                    if infectionWalkTrack then infectionWalkTrack:Stop(); infectionWalkTrack = nil end
                                    if infectionRunTrack then infectionRunTrack:Stop(); infectionRunTrack = nil end
                                    if newState == "idle" then
                                        infectionIdleTrack = playAnimationOnHumanoid(INFECTION_ANIM_IDLE, true)
                                    elseif newState == "walk" then
                                        infectionWalkTrack = playAnimationOnHumanoid(INFECTION_ANIM_WALK, true)
                                    elseif newState == "run" then
                                        infectionRunTrack = playAnimationOnHumanoid(INFECTION_ANIM_RUN, true)
                                    end
                                end
                            end
                            task.wait(0.2)
                        end
                    end
                    task.spawn(stateMachine)

                    task.wait(60)
                    if infectionIsRunning and humanoid and humanoid.Health > 0 then
                        humanoid.Health = 0
                    end
                    stopInfection()
                    canInfect = true
                end)
            end
        end)
    else
        local suicideAnimId = "rbxassetid://82480275101558"
        local animator = humanoid:FindFirstChildOfClass("Animator") or Instance.new("Animator", humanoid)
        local anim = Instance.new("Animation")
        anim.AnimationId = suicideAnimId
        local track = animator:LoadAnimation(anim)
        track:Play()
        track.Stopped:Wait()
        humanoid.Health = 0
        canInfect = true
    end

    humanoid.Died:Connect(function()
        if InfectionActive then
            local suicideAnimId = "rbxassetid://82480275101558"
            local animator = humanoid:FindFirstChildOfClass("Animator") or Instance.new("Animator", humanoid)
            local anim = Instance.new("Animation")
            anim.AnimationId = suicideAnimId
            local track = animator:LoadAnimation(anim)
            track:Play()
            track.Stopped:Wait()
        end
        stopInfection()
        canInfect = true
    end)

    table.insert(InfectionCleanupFunctions, function()
        infectionIsRunning = false
        InfectionActive = false
        canInfect = true
        local hrp = char:FindFirstChild("HumanoidRootPart")
        if hrp then hrp.Anchored = false end
        if humanoid then
            humanoid.PlatformStand = false
            humanoid.WalkSpeed = Config.SpeedHackEnabled and Config.WalkSpeedValue or 9
            humanoid.JumpPower = Config.JumpPowerEnabled and Config.JumpPowerValue or 50
        end
        local tracks = {infectionInjuredTrack, infectionHeadShakeTrack, infectionCoughTrack, infectionUnstableTrack,
                        infectionFallTrack, infectionLurkerTrack, infectionIdleTrack, infectionWalkTrack, infectionRunTrack}
        for _, t in ipairs(tracks) do
            if t then t:Stop(); t = nil end
        end
        infectionTransformDone = false
        showBloodVignette(false)
        local cc = Lighting:FindFirstChild("InfectionRedTint")
        if cc then cc:Destroy() end
        local effectsGui = LocalPlayer.PlayerGui:FindFirstChild("InfectionEffectsGui")
        if effectsGui then effectsGui:Destroy() end
    end)
end

local function ApplyHitboxToHead(part, enable)
    if not part or not part:IsA("BasePart") then return end
    if part.Name ~= "Head" then return end
    local model = part.Parent
    if not isHumanoidModel(model) or isPlayerCharacter(model) then return end
    if model == LocalPlayer.Character then return end
    pcall(function()
        if enable then
            if not HitboxModifiedHeads[part] then
                HitboxModifiedHeads[part] = {
                    Size = part.Size,
                    Transparency = part.Transparency,
                    CanCollide = part.CanCollide
                }
            end
            part.Size = Vector3.new(4, 4, 4)
            part.CanCollide = false
            part.Transparency = 0.5
        else
            local original = HitboxModifiedHeads[part]
            if original then
                part.Size = original.Size
                part.CanCollide = original.CanCollide
                part.Transparency = original.Transparency
                HitboxModifiedHeads[part] = nil
            end
        end
    end)
end

local function UpdateAllHitboxes(enable)
    for _, part in ipairs(Workspace:GetDescendants()) do
        if part:IsA("BasePart") and part.Name == "Head" then
            local model = part.Parent
            if isHumanoidModel(model) and not isPlayerCharacter(model) then
                ApplyHitboxToHead(part, enable)
            end
        end
    end
end

Workspace.DescendantAdded:Connect(function(desc)
    if HitboxEnabled and desc:IsA("BasePart") and desc.Name == "Head" then
        local model = desc.Parent
        if isHumanoidModel(model) and not isPlayerCharacter(model) and model ~= LocalPlayer.Character then
            ApplyHitboxToHead(desc, true)
        end
    end
    if desc:IsA("BasePart") then
        desc:GetPropertyChangedSignal("Name"):Connect(function()
            if HitboxEnabled and desc.Name == "Head" then
                local model = desc.Parent
                if isHumanoidModel(model) and not isPlayerCharacter(model) and model ~= LocalPlayer.Character then
                    ApplyHitboxToHead(desc, true)
                end
            end
        end)
    end
end)

local function cleanFly()
    if flyBV then flyBV:Destroy(); flyBV = nil end
    if flyBG then flyBG:Destroy(); flyBG = nil end
    if flyWeld then flyWeld:Destroy(); flyWeld = nil end
    if flySeat then flySeat:Destroy(); flySeat = nil end
    local char = LocalPlayer.Character
    local hum = char and char:FindFirstChildOfClass("Humanoid")
    if hum then
        hum.PlatformStand = false
        hum:SetStateEnabled(Enum.HumanoidStateType.Seated, true)
        if hum.SeatPart then hum.Sit(false) end
    end
    flyActive = false
end

local function enableFly(enable)
    if not enable then
        cleanFly()
        return
    end
    local char = LocalPlayer.Character
    if not char then return end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    local hum = char:FindFirstChildOfClass("Humanoid")
    if not hrp or not hum then return end

    cleanFly()
    flyActive = true

    if CurrentFlyType == "CFrame" then
        hum.PlatformStand = true
        flyBV = Instance.new("BodyVelocity")
        flyBV.MaxForce = Vector3.new(0, 1e6, 0)
        flyBV.Velocity = Vector3.new(0, 0, 0)
        flyBV.Parent = hrp
    elseif CurrentFlyType == "BodyVelocity [BEST]" then
        flyBV = Instance.new("BodyVelocity")
        flyBV.MaxForce = Vector3.new(1e6, 1e6, 1e6)
        flyBV.Parent = hrp
        flyBG = Instance.new("BodyGyro")
        flyBG.MaxTorque = Vector3.new(1e6, 1e6, 1e6)
        flyBG.Parent = hrp
    elseif CurrentFlyType == "Seat [UNDETECTED]" then
        flySeat = Instance.new("VehicleSeat")
        flySeat.Size = Vector3.new(1, 1, 1)
        flySeat.Transparency = 1
        flySeat.CanCollide = false
        flySeat.Parent = workspace
        flyWeld = Instance.new("Weld")
        flyWeld.Part0 = hrp
        flyWeld.Part1 = flySeat
        flyWeld.C0 = CFrame.new(0, -1.5, 0)
        flyWeld.Parent = flySeat
        hum.Sit = true
        hum.PlatformStand = true
        hum:SetStateEnabled(Enum.HumanoidStateType.Seated, false)
        flyBV = Instance.new("BodyVelocity")
        flyBV.MaxForce = Vector3.new(1e6, 1e6, 1e6)
        flyBV.Parent = flySeat
        flyBG = Instance.new("BodyGyro")
        flyBG.MaxTorque = Vector3.new(1e6, 1e6, 1e6)
        flyBG.Parent = flySeat
    end
end

RunService.Heartbeat:Connect(function(dt)
    if not flyActive then return end
    local char = LocalPlayer.Character
    if not char then return end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    local hum = char:FindFirstChildOfClass("Humanoid")
    if not hrp or not hum then return end

    local move = Vector3.new()
    if UserInputService:IsKeyDown(Enum.KeyCode.W) then move = move + Camera.CFrame.LookVector end
    if UserInputService:IsKeyDown(Enum.KeyCode.S) then move = move - Camera.CFrame.LookVector end
    if UserInputService:IsKeyDown(Enum.KeyCode.A) then move = move - Camera.CFrame.RightVector end
    if UserInputService:IsKeyDown(Enum.KeyCode.D) then move = move + Camera.CFrame.RightVector end
    if UserInputService:IsKeyDown(Enum.KeyCode.Space) then move = move + Vector3.new(0, 1, 0) end
    if UserInputService:IsKeyDown(Enum.KeyCode.LeftShift) then move = move - Vector3.new(0, 1, 0) end

    if move.Magnitude > 0 then move = move.Unit end
    local speed = FlySpeed * dt

    if CurrentFlyType == "CFrame" then
        hrp.CFrame = hrp.CFrame + move * speed
        if hrp.Position.Y < -500 then
            hrp.CFrame = CFrame.new(hrp.Position.X, 0, hrp.Position.Z)
        end
    elseif CurrentFlyType == "BodyVelocity [BEST]" and flyBV and flyBG then
        flyBG.CFrame = Camera.CFrame
        flyBV.Velocity = move * FlySpeed
    elseif CurrentFlyType == "Seat [UNDETECTED]" and flyBV and flyBG and flySeat then
        flyBG.CFrame = Camera.CFrame
        flyBV.Velocity = move * FlySpeed
    end
end)

local XrayEnabled = false
local XrayDistance = 30
local XrayMaterial = Enum.Material.ForceField
local XrayTransparency = 0.3
local XrayModifiedParts = {}
local XrayLoop = nil

local function applyXrayToPart(part, enable)
    if not part:IsA("BasePart") then return end
    if enable then
        if not XrayModifiedParts[part] then
            XrayModifiedParts[part] = {
                Material = part.Material,
                Transparency = part.Transparency
            }
            part.Material = XrayMaterial
            part.Transparency = XrayTransparency
        else
            part.Material = XrayMaterial
            part.Transparency = XrayTransparency
        end
    else
        local data = XrayModifiedParts[part]
        if data then
            part.Material = data.Material
            part.Transparency = data.Transparency
            XrayModifiedParts[part] = nil
        end
    end
end

local function updateXrayMaterialAndTransparency()
    if not XrayEnabled then return end
    for part, data in pairs(XrayModifiedParts) do
        if part and part:IsA("BasePart") then
            pcall(function()
                part.Material = XrayMaterial
                part.Transparency = XrayTransparency
            end)
        end
    end
end

local function updateXray()
    if not XrayEnabled then
        if XrayLoop then XrayLoop:Disconnect(); XrayLoop = nil end
        for part, _ in pairs(XrayModifiedParts) do
            pcall(function() applyXrayToPart(part, false) end)
        end
        table.clear(XrayModifiedParts)
        return
    end

    if XrayLoop then XrayLoop:Disconnect() end
    XrayLoop = RunService.Heartbeat:Connect(function()
        if not XrayEnabled then return end
        local char = LocalPlayer.Character
        if not char then return end
        local hrp = char:FindFirstChild("HumanoidRootPart")
        if not hrp then return end

        local radius = XrayDistance
        local nearbyParts = Workspace:GetPartBoundsInRadius(hrp.Position, radius)
        local currentSet = {}
        for _, part in ipairs(nearbyParts) do
            if part:IsA("BasePart") and not part:IsDescendantOf(char) then
                currentSet[part] = true
                if not XrayModifiedParts[part] then
                    applyXrayToPart(part, true)
                else
                    if part.Material ~= XrayMaterial or part.Transparency ~= XrayTransparency then
                        part.Material = XrayMaterial
                        part.Transparency = XrayTransparency
                    end
                end
            end
        end
        for part in pairs(XrayModifiedParts) do
            if not currentSet[part] then
                applyXrayToPart(part, false)
            end
        end
    end)
end

local function updateSilencers(state)
    local backpack = LocalPlayer:FindFirstChild("Backpack")
    if backpack then
        for _, item in ipairs(backpack:GetChildren()) do
            if item:GetAttribute("IsGun") == true then
                item:SetAttribute("Silencer", state)
            end
        end
    end
    local char = LocalPlayer.Character
    if char then
        for _, item in ipairs(char:GetChildren()) do
            if item:IsA("Tool") and item:GetAttribute("IsGun") == true then
                item:SetAttribute("Silencer", state)
            end
        end
    end
end

local function checkAndApplySilencer(item)
    if item:GetAttribute("IsGun") == true then
        local isEnabled = Config.SilencerEnabled
        item:SetAttribute("Silencer", isEnabled)
    end
end

local function listenToBackpack(currentBackpack)
    if not currentBackpack then return end
    currentBackpack.ChildAdded:Connect(function(item)
        task.wait(0.1)
        checkAndApplySilencer(item)
    end)
end

if LocalPlayer.Character then
    LocalPlayer.Character.ChildAdded:Connect(function(item)
        if item:IsA("Tool") then
            task.wait(0.1)
            checkAndApplySilencer(item)
            updateSilencers(Config.SilencerEnabled)
        end
    end)
end

LocalPlayer.CharacterAdded:Connect(function(char)
    task.wait(1)
    local backpack = LocalPlayer:WaitForChild("Backpack")
    listenToBackpack(backpack)
    char.ChildAdded:Connect(function(item)
        if item:IsA("Tool") then
            task.wait(0.1)
            checkAndApplySilencer(item)
            updateSilencers(Config.SilencerEnabled)
        end
    end)
    updateSilencers(Config.SilencerEnabled)
end)

