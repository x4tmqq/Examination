local function applyNametags(char)
    local head = char and char:FindFirstChild("Head")
    if not head then return end
    local tag = head:FindFirstChild("NameTag")
    if not tag then
        tag = head:WaitForChild("NameTag", 5)
        if not tag then return end
    end
    tag.CharacterName.TextColor3 = Config.TagColor
    tag.Rank.TextColor3 = Config.TagColor
    tag.Username.TextColor3 = Config.TagColor
    if Config.CharacterName ~= "" then
        tag.CharacterName.Text = "[" .. Config.CharacterName .. "]"
    else
        tag.CharacterName.Text = ""
    end
    if Config.CharacterRank ~= "" then
        tag.Rank.Text = "[" .. Config.CharacterRank .. "]"
    else
        tag.Rank.Text = ""
    end
end

